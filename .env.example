# ModernTensor Environment Configuration
# Copy this file to .env and update with your actual values
#
# Quick Start:
#   1. cp .env.example .env
#   2. Get Hedera testnet account: https://portal.hedera.com
#   3. Fill in HEDERA_ACCOUNT_ID and HEDERA_PRIVATE_KEY
#   4. Run: python scripts/setup_hedera.py

# =============================================================================
# HEDERA NETWORK SETTINGS (Required)
# For Hedera Hello Future Hackathon 2026
# =============================================================================

# Network: testnet, mainnet, or previewnet
HEDERA_NETWORK="testnet"

# Account credentials (get from Hedera Portal: portal.hedera.com)
HEDERA_ACCOUNT_ID="0.0.XXXXX"
HEDERA_PRIVATE_KEY="302e020100300506032b657004220420..."

# =============================================================================
# HCS Topics (Auto-created by setup_hedera.py)
# =============================================================================

# HEDERA_REGISTRATION_TOPIC_ID="0.0.XXXXX"
# HEDERA_SCORING_TOPIC_ID="0.0.XXXXX"
# HEDERA_TASK_TOPIC_ID="0.0.XXXXX"

# =============================================================================
# HTS Token & Smart Contracts (Auto-created by setup_hedera.py)
# =============================================================================

# HEDERA_MDT_TOKEN_ID="0.0.XXXXX"
# HEDERA_PAYMENT_ESCROW_CONTRACT_ID="0.0.XXXXX"
# HEDERA_SUBNET_REGISTRY_CONTRACT_ID="0.0.XXXXX"

# =============================================================================
# LLM API KEYS (for AI Validation — at least one required)
# =============================================================================

# OpenAI (recommended) — https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Anthropic Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY="sk-ant-..."

# Google Gemini — https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY="AIza..."

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Custom mirror node URL (uses default if not set)
# HEDERA_MIRROR_NODE_URL="https://testnet.mirrornode.hedera.com"

# Transaction settings
HEDERA_MAX_TRANSACTION_FEE=10000000  # 0.1 HBAR in tinybars
HEDERA_TRANSACTION_TIMEOUT=30  # seconds

# ModernTensor — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get a free Hedera testnet account at:
#   https://portal.hedera.com/register

# -----------------------------------------------------------------------
# Hedera Network
# -----------------------------------------------------------------------
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=302e...your-private-key

# -----------------------------------------------------------------------
# HCS Topics (created by scripts/setup_hedera.py)
# -----------------------------------------------------------------------
HEDERA_REGISTRATION_TOPIC_ID=0.0.XXXXX
HEDERA_SCORING_TOPIC_ID=0.0.XXXXX
HEDERA_TASK_TOPIC_ID=0.0.XXXXX

# -----------------------------------------------------------------------
# HTS Token
# -----------------------------------------------------------------------
HTS_TOKEN_ID_MDT=0.0.XXXXX

# -----------------------------------------------------------------------
# Smart Contracts (deployed by scripts/deploy_contracts.py)
# -----------------------------------------------------------------------
CONTRACT_ID_SUBNET_REGISTRY=0.0.XXXXX
CONTRACT_ID_PAYMENT_ESCROW=0.0.XXXXX

# -----------------------------------------------------------------------
# AI Validator Agent — LLM API Keys (at least one required)
# -----------------------------------------------------------------------
# OpenAI (recommended)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Anthropic (alternative)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Google Gemini (alternative)
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------
# Miner Configuration
# -----------------------------------------------------------------------
MINER_PORT=8091
MDT_STAKE_AMOUNT=100

# -----------------------------------------------------------------------
# Faucet Configuration (for scripts/faucet_server.py)
# -----------------------------------------------------------------------
FAUCET_PORT=8888
FAUCET_DEFAULT_DRIP=100
FAUCET_MAX_DRIP=500
FAUCET_DAILY_BUDGET=10000
FAUCET_COOLDOWN=3600

# -----------------------------------------------------------------------
# Faucet URL (for mtcli faucet command)
# -----------------------------------------------------------------------
MDT_FAUCET_URL=http://localhost:8888
